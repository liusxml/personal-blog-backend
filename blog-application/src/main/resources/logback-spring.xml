<?xml version="1.0" encoding="UTF-8"?>
<!--
    ================================================================================
     企业级 Logback 日志配置文件 (Cloud-Native Edition)
    ================================================================================
    设计哲学:
    1.  [完全掌控] 不依赖 Spring Boot 的 `base.xml`，手动定义所有组件。
    2.  [环境隔离] 文件 Appender 仅在 dev/debug 环境声明；
                   生产(prod)环境只声明 Console Appender，确保 Logback 不会尝试
                   创建任何磁盘文件——彻底解决容器内缺少 /logs 目录导致的启动失败。
    3.  [表述清晰] 每个 springProfile 块自给自足，阅读配置时无需跨越文件全局去理解。
-->
<configuration>

    <!-- ================================================================================= -->
    <!--  1. 核心属性与规则定义 (Core Properties & Rules)                               -->
    <!-- ================================================================================= -->

    <springProperty scope="context" name="APP_NAME" source="spring.application.name"
                    defaultValue="personal-blog-backend"/>
    <conversionRule conversionWord="clr" class="org.springframework.boot.logging.logback.ColorConverter"/>

    <!-- ================================================================================= -->
    <!--  2. 全局 Appender（所有 Profile 均可用，不涉及磁盘 I/O）                        -->
    <!-- ================================================================================= -->

    <!-- 彩色控制台（开发阶段 / 降级 fallback）-->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %clr(%-5level){blue} [%clr(%thread){magenta}] [%X{traceId}/%X{spanId}]
                %clr(%logger{40}){cyan}: %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- JSON Console Appender（云原生 12-Factor App — 生产环境输出到 stdout）-->
    <!-- Docker Daemon 负责日志轮转，Alloy 侧车负责采集并推送到 Grafana Cloud Loki -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- 自动包含 MDC 中的 traceId / spanId（OTel Agent 注入）-->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <!-- 自定义字段 -->
            <customFields>{"app":"${APP_NAME}","env":"prod"}</customFields>
            <!-- ISO8601 时间戳，便于 Loki 解析 -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        </encoder>
    </appender>

    <appender name="ASYNC_JSON_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="JSON_CONSOLE"/>
        <neverBlock>true</neverBlock>
        <queueSize>1024</queueSize>
        <discardingThreshold>204</discardingThreshold>
        <includeCallerData>false</includeCallerData>
    </appender>

    <!-- ================================================================================= -->
    <!--  3. Profile-specific 配置（各 Profile 自给自足）                               -->
    <!-- ================================================================================= -->

    <!-- ── 生产环境 ────────────────────────────────────────────────────────────────────── -->
    <!-- 只使用 ASYNC_JSON_CONSOLE，无任何磁盘文件操作                                   -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        </root>

        <!-- 项目日志保持 INFO，允许业务日志完整上报 -->
        <logger name="com.blog" level="INFO"/>

        <!-- 框架日志过滤到 WARN，减少 Loki 存储噪音 -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.apache" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
    </springProfile>

    <!-- ── 开发 / 调试环境 ──────────────────────────────────────────────────────────────── -->
    <!-- 文件 Appender 声明在此 Profile 块内，prod 环境不会创建这些 Appender              -->
    <springProfile name="dev, debug">

        <property name="LOG_HOME" value="./logs"/>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_HOME}/${APP_NAME}.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_HOME}/${APP_NAME}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>200MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{traceId}/%X{spanId}] %logger{40}: %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="FILE"/>
            <neverBlock>true</neverBlock>
            <queueSize>1024</queueSize>
            <discardingThreshold>204</discardingThreshold>
            <maxFlushTime>5000</maxFlushTime>
            <includeCallerData>false</includeCallerData>
        </appender>

        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_HOME}/${APP_NAME}-error.log</file>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>ERROR</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_HOME}/${APP_NAME}-error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>60</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40}: %msg%n%ex{full}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <appender name="ASYNC_ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="ERROR_FILE"/>
            <neverBlock>false</neverBlock>
            <queueSize>256</queueSize>
            <discardingThreshold>0</discardingThreshold>
        </appender>

        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR_FILE"/>
        </root>

        <logger name="com.baomidou.mybatisplus.core.mapper" level="DEBUG"/>
        <logger name="java.sql.PreparedStatement" level="DEBUG"/>
    </springProfile>

    <!-- ── 测试环境 ──────────────────────────────────────────────────────────────────────── -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.baomidou.mybatisplus.core.mapper" level="DEBUG"/>
    </springProfile>

    <!-- ── 默认 fallback（未指定 Profile 时）──────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
